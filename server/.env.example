# Turboconnect — przykładowa konfiguracja serwera
# Skopiuj: cp .env.example .env

# Sesja Flask (opcjonalnie; bez tego tworzy się server/secret.key)
TURBOCONNECT_SECRET=zmien-na-losowy-ciag-znakow

# Logowanie do panelu WWW
TURBOCONNECT_USER=admin
TURBOCONNECT_PASS=zmien-haslo

# Pełny traceback w odpowiedziach 500 (tylko dev)
# TURBOCONNECT_DEBUG=1

# FFmpeg — wymagany do konwersji i niektórych formatów
FFMPEG_PATH=/usr/bin/ffmpeg

# Spotify Developer Dashboard — opcjonalnie, do importu playlist
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# SPOTIFY_MARKET=PL
