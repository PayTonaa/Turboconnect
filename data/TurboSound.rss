	{
	buttons =
		{
		CBA_BUTTON { id = EAknSoftkeyOptions; txt = "Opcje"; },
		CBA_BUTTON { id = ECmdSearch; txt = "Szukaj"; },
		CBA_BUTTON { id = ECmdPlay; txt = "Play"; }
		};
	}


