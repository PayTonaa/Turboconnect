// ---------------------------------------------------------------------------
// Single-line text query dialog for "Pobierz z internetu".
// ---------------------------------------------------------------------------
RESOURCE DIALOG r_fetch_query_dialog
	{
	flags = EGeneralQueryFlags;
	buttons = R_AVKON_SOFTKEYS_OK_CANCEL;
	items =
		{
		DLG_LINE
			{
			type = EAknCtQuery;
			id = EGeneralQuery;
			control = AVKON_DATA_QUERY
				{
				layout = EDataLayout;
				label = qtn_fetch_prompt;
				control = EDWIN
					{
					flags = EEikEdwinNoHorizScrolling;
					width = 30;
					lines = 1;
					maxlength = 80;
					};
				};
			}
		};
	}

